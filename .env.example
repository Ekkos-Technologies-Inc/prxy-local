# prxy-local — environment configuration
# Copy this to `.env` and fill in the bits you need.

# ─── Server ────────────────────────────────────────────────────────
PORT=3099
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── Local mode (always true for prxy-local) ─────────────────────
LOCAL_MODE=true

# Where SQLite + blobs + evictions live.
PRXY_DATA_DIR=./data

# Optional gateway auth — if set, requests must send Bearer <LOCAL_API_KEY>.
# Leave unset for fully open (single-user, single-machine) operation.
# LOCAL_API_KEY=prxy_local_choose_a_long_random_string

# ─── Provider keys (set the ones you use) ───────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GOOGLE_API_KEY=AIzaSy...                # Gemini API key from aistudio.google.com
# GROQ_API_KEY=gsk_...                    # Groq Cloud key from console.groq.com

# ─── AWS Bedrock (optional, 5th provider) ─────────────────────
# Use Claude / Llama / Titan / Mistral / Cohere through your AWS account.
# Auth: env vars OR shared credential file OR IAM role (preferred when
# running on EC2/ECS/App Runner). The Bedrock client uses the SDK default
# credential chain when no explicit accessKeyId/secret is given.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Routing examples (model → provider auto-detected):
#   - claude-sonnet-4-6, claude-haiku-4-5  → Anthropic
#   - gpt-4o, gpt-4o-mini, o3, o4-mini      → OpenAI
#   - gemini-2.0-flash, gemini-2.0-pro     → Google
#   - llama-3.3-70b-versatile, mixtral-*   → Groq
#   - bedrock/anthropic.claude-sonnet-4-20250514-v1:0  → AWS Bedrock
#   - bedrock/meta.llama3-70b-instruct-v1:0            → AWS Bedrock
#   - bedrock/amazon.titan-text-express-v1             → AWS Bedrock

# ─── Blob backend (default: filesystem) ────────────────────────
# 'fs'  — store blobs at <PRXY_DATA_DIR>/blobs/ (default; right for laptops + homelab).
# 's3'  — store blobs in an S3 bucket (right for "local-mode-on-AWS" deploys
#          where you want blobs to survive instance churn). Requires AWS_REGION
#          and S3_BUCKET; credentials via the SDK default chain or env vars.
# BLOB_BACKEND=fs
# S3_BUCKET=prxy-local-blobs

# ─── Embeddings (used by semantic-cache + patterns + mcp-optimizer)
# Falls back to a deterministic stub if neither is set — fine for tests
# and lightweight local use, but real embeddings give much better recall.
# VOYAGE_API_KEY=...
# EMBEDDING_MODEL=voyage-3-lite

# ─── Pipeline configuration ────────────────────────────────────
# Comma-separated module names. Order matters.
# Defaults to: mcp-optimizer,semantic-cache,patterns
# PRXY_PIPE=mcp-optimizer,semantic-cache,patterns

# Optional YAML-format pipeline file (lets you parameterize each module).
# PRXY_PIPE_FILE=./pipeline.yaml

# Identifier shown in /health.
# GIT_SHA=local-dev
