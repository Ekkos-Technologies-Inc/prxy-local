{
  "name": "prxy-local",
  "version": "0.4.0",
  "description": "Open-source local edition of prxy.monster — a composable AI gateway you run on your own machine.",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "prxy": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "node -e \"const fs=require('fs'),path=require('path');const s=path.join('src','storage','migrations'),d=path.join('dist','storage','migrations');fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))fs.copyFileSync(path.join(s,f),path.join(d,f));\"",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prxy": "tsx src/cli.ts",
    "migrate": "tsx -e \"import('./src/storage/db.js').then(async (m) => { const a = new m.LocalDbAdapter(); await a.init(); console.log('migrations applied'); await a.shutdown(); })\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@google/genai": "^1.50.1",
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.0",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "ai",
    "gateway",
    "llm",
    "anthropic",
    "openai",
    "google",
    "gemini",
    "groq",
    "bedrock",
    "aws",
    "claude",
    "gpt",
    "llama",
    "proxy",
    "self-hosted",
    "local-first",
    "privacy",
    "airgap"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ekkos-Technologies-Inc/prxy-local.git"
  },
  "homepage": "https://prxy.monster",
  "bugs": {
    "url": "https://github.com/Ekkos-Technologies-Inc/prxy-local/issues"
  }
}
